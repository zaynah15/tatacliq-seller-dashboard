# =============================================
# TataCLiQ Seller Dashboard - Environment vars
# Copy to .env.local in apps/web and .env in apps/api
# =============================================

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="TataCLiQ Seller Dashboard"
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Database (Postgres) ---
DATABASE_URL="postgresql://seller_admin:change_me_in_env@localhost:5432/seller_dashboard"

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Gmail API (OAuth2) ---
# Create at https://console.cloud.google.com → APIs & Services → Credentials → OAuth Client ID (Web)
# Add http://localhost:3000/api/auth/gmail/callback as authorized redirect URI
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback
# The Gmail account the dashboard monitors for seller emails
GMAIL_MONITORED_ACCOUNT=zaynah15mahmood@gmail.com
# Source seller email used for testing
SELLER_TEST_EMAIL=liyana2015za@gmail.com

# --- Gemini Pro API ---
# Get from https://aistudio.google.com/app/apikey (use the zaynah15mahmood@gmail.com account)
GEMINI_API_KEY=your-gemini-pro-api-key
GEMINI_MODEL=gemini-1.5-pro-latest
GEMINI_VISION_MODEL=gemini-1.5-pro-latest

# --- AWS S3 (or Cloudinary) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=tatacliq-seller-uploads
# OR use Cloudinary:
# CLOUDINARY_URL=cloudinary://...

# --- NextAuth / session ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- Python worker ---
PYTHON_WORKER_URL=http://localhost:8000
