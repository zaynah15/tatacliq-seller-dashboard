{
  "name": "@tatacliq/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "workers": "concurrently -n parse,enrich,image,validate,sheet,notify \"tsx src/workers/parse.worker.ts\" \"tsx src/workers/enrich.worker.ts\" \"tsx src/workers/image.worker.ts\" \"tsx src/workers/validate.worker.ts\" \"tsx src/workers/sheet.worker.ts\" \"tsx src/workers/notify.worker.ts\"",
    "worker:parse": "tsx src/workers/parse.worker.ts",
    "worker:enrich": "tsx src/workers/enrich.worker.ts",
    "worker:image": "tsx src/workers/image.worker.ts",
    "worker:validate": "tsx src/workers/validate.worker.ts",
    "worker:sheet": "tsx src/workers/sheet.worker.ts",
    "worker:notify": "tsx src/workers/notify.worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx ../../scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.633.0",
    "@aws-sdk/s3-request-presigner": "^3.633.0",
    "@prisma/client": "^5.18.0",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "node-fetch": "^3.3.2",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "concurrently": "^8.2.2",
    "prisma": "^5.18.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
